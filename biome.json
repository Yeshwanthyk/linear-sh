{
  "$schema": "https://biomejs.dev/schemas/latest/schema.json",
  "files": {
    "ignore": ["bin/**", "dist/**"]
  },
  "linter": {
    "enabled": true,
    "rules": {
      "style": {
        "noNonNullAssertion": "off",
        "useTemplate": "off"
      }
    }
  },
  "formatter": {
    "enabled": false
  },
  "organizeImports": {
    "enabled": false
  }
}
